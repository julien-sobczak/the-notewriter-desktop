{
  "include": ["src/renderer/src/env.d.ts", "src/**/*"],
  "compilerOptions": {
    "jsx": "react-jsx",
    "target": "es2021",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "@renderer/*": ["src/renderer/src/*"]
    }
  }
}
